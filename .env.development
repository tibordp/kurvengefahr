# Loaded by Vite in dev mode only (plain `vite build` runs in production mode and ignores it).
# Points the share feature at the local dev stack:
#   docker compose -f share-api/dev/compose.yml up --build
# With the stack down, the Share menu still shows and fails with a clear in-dialog error.
VITE_SHARE_API_URL=http://localhost:8787
